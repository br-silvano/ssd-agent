# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Workspace ─────────────────────────────────────────────────────────────────
# Diretório raiz onde os artefatos do pipeline são salvos.
# Padrão: ./workspace (relativo ao cwd onde o agente é iniciado)
# SSD_WORKSPACE=./workspace

# ── Modelo ────────────────────────────────────────────────────────────────────
# Modelo padrão para todos os agentes do pipeline.
# SSD_MODEL=claude-sonnet-4-20250514

# ── LangSmith (opcional — tracing/observabilidade) ───────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=ssd-agent
